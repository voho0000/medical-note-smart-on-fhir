# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright (e2e)
/test-results/
/playwright-report/
/playwright/.cache/
# local-only real FHIR bundles for E2E (never commit real patient data)
/e2e/fixtures/local/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore real env files but keep the redacted example tracked
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*.pdf

# IDE and editor files
.claude

# build-gh.mjs temp stash (left behind if a GH Pages build is interrupted)
.api-stash-gh-build/

# loop-engineering working files — verdict output + per-iteration goal
/.loop/
/scripts/loop/goal.md
