# =============================================================================
# SMART on FHIR Configuration
# =============================================================================

# SMART Client ID (optional, defaults to "my_web_app"). This is a PUBLIC
# registered client identifier, not a secret. The app uses public client +
# PKCE only — there is no client-secret / confidential-client mode (a static
# front end can't keep a secret).
NEXT_PUBLIC_SMART_CLIENT_ID=my_web_app

# Additional trusted SMART issuer origins, comma-separated. Unknown issuers are
# still usable, but the app shows an explicit confirmation screen first.
NEXT_PUBLIC_SMART_ALLOWED_ISS=

# =============================================================================
# Deployment Configuration
# =============================================================================

# Build-time deployment boundary. Normal development and the official
# mediprisma/GitHub Pages scripts use cloud. `build:onprem` overrides this to
# onprem and also sets the legacy fail-closed flag below.
NEXT_PUBLIC_DEPLOYMENT_PROFILE=cloud

# Set to "true" when deploying to GitHub Pages
GITHUB_PAGES=

# Base path for GitHub Pages deployment
NEXT_PUBLIC_BASE_PATH=/medical-note-smart-on-fhir

# Alternative static-export base path (for example /app on mediprisma.tw).
# Leave blank for normal dev / Node hosting. build:mediprisma sets this itself.
DEPLOY_BASE_PATH=

# Legacy compatibility flag. `1` always forces the safer onprem profile even if
# another value says cloud. Prefer `npm run build:onprem` over setting it by hand.
NEXT_PUBLIC_OFFLINE_MODE=0

# Comma-separated exact origins allowed for cross-origin hospital AI gateways
# in onprem artifacts. Same-origin paths and loopback development need no entry.
# The onprem build reads this from the ignored `.env.intranet` file.
NEXT_PUBLIC_ONPREM_AI_ALLOWED_ORIGINS=

# =============================================================================
# API Keys and Proxy Configuration
# =============================================================================
# Local dev should point the six *_URL vars at the dev-* function group
# (e.g. https://dev-proxychatcompletion-....run.app) — its CORS only allows
# localhost:3001, so prod stays isolated. Production URLs (un-prefixed) are
# injected from GitHub secrets by the CI/gh-pages workflows.

# Chat API endpoint
NEXT_PUBLIC_CHAT_URL=

# Whisper API endpoint for speech-to-text
NEXT_PUBLIC_WHISPER_URL=

# Gemini API endpoint
NEXT_PUBLIC_GEMINI_URL=
NEXT_PUBLIC_CLAUDE_URL=

# Optional BYO OpenAI-compatible Firebase Gateway. Unlike direct mode, prompts,
# responses, endpoint metadata, and the user's upstream key transit Firebase.
NEXT_PUBLIC_OPENAI_COMPATIBLE_GATEWAY_URL=

# Proxy authentication key
NEXT_PUBLIC_PROXY_KEY=

# Abort an AI stream after this many milliseconds without a new token/event.
# Defaults to 60000 when blank or invalid.
NEXT_PUBLIC_STREAM_IDLE_TIMEOUT_MS=60000

# =============================================================================
# Firebase Configuration
# =============================================================================

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase App Check (reCAPTCHA v3) for proxy anti-abuse. The debug token is
# local/headless development only and must never be injected into production.
NEXT_PUBLIC_APPCHECK_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_APPCHECK_DEBUG=

# E2E only: routes Auth and Firestore to local emulators when exactly "1".
NEXT_PUBLIC_FIREBASE_EMULATOR=

# =============================================================================
# Additional Services
# =============================================================================

# Perplexity API proxy URL
NEXT_PUBLIC_PERPLEXITY_PROXY_URL=

# Feedback service URL (production: Firebase Function endpoint)
NEXT_PUBLIC_FEEDBACK_URL=

# --- Dev / self-host only: the built-in Next API route at /api/feedback ---
# These power the local fallback feedback route (next dev / a Node host).
# They are NOT used by the static GitHub Pages build. Leave blank to have
# the route accept feedback without sending email.
RESEND_API_KEY=
FEEDBACK_TO_EMAIL=
