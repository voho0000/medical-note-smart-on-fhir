# Explicit deployment boundary. `npm run build:onprem` forces both values, so
# a shell containing cloud secrets cannot turn this artifact back into cloud.
NEXT_PUBLIC_DEPLOYMENT_PROFILE=onprem
NEXT_PUBLIC_OFFLINE_MODE=1

# Public SMART client registration for the internal EHR.
NEXT_PUBLIC_SMART_CLIENT_ID=my_web_app
NEXT_PUBLIC_SMART_ALLOWED_ISS=https://fhir.intra.example.org

# Optional comma-separated origins for cross-origin internal AI gateways.
# Same-origin paths such as /ai/v1 and loopback development need no entry.
NEXT_PUBLIC_ONPREM_AI_ALLOWED_ORIGINS=https://llm.intra.example.org

# Keep cloud integrations blank in the air-gapped artifact.
NEXT_PUBLIC_CHAT_URL=
NEXT_PUBLIC_WHISPER_URL=
NEXT_PUBLIC_GEMINI_URL=
NEXT_PUBLIC_CLAUDE_URL=
NEXT_PUBLIC_PERPLEXITY_PROXY_URL=
NEXT_PUBLIC_FEEDBACK_URL=
NEXT_PUBLIC_APPCHECK_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_PROXY_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
